# This .gitignore is for Unity projects.

# ======================================
# Unity-generated files and folders
# ======================================

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/

# ======================================
# OS-generated files
# ======================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ======================================
# IDE / Editor files
# ======================================

.vs/
.idea/
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Rider
.idea/
*.sln.iml

# Visual Studio
.vs/
*.csproj
*.csproj.user
*.sln
*.sln.docstates

# ======================================
# Build outputs
# ======================================

*.apk
*.aab
*.unitypackage
*.app

# ======================================
# Git LFS lock file
# ======================================

.lfs-lock

# ======================================
# Per-project private settings (Antigravity IDE)
# ======================================

*.private.0
